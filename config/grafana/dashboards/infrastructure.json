{
  "dashboard": {
    "id": null,
    "uid": "divestreams-infra",
    "title": "DiveStreams - Infrastructure",
    "tags": ["divestreams", "infrastructure"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Container CPU",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": "grafanacloud-prom"},
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total[5m])",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"lineWidth": 2},
            "unit": "percentunit"
          }
        },
        "options": {
          "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      {
        "id": 2,
        "title": "Container Memory",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "datasource": {"type": "prometheus", "uid": "grafanacloud-prom"},
        "targets": [
          {
            "expr": "process_resident_memory_bytes",
            "legendFormat": "{{job}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"lineWidth": 2},
            "unit": "bytes"
          }
        },
        "options": {
          "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      {
        "id": 3,
        "title": "Queue Depth by Queue",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "datasource": {"type": "prometheus", "uid": "grafanacloud-prom"},
        "targets": [
          {
            "expr": "queue_depth",
            "legendFormat": "{{queue}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"lineWidth": 2}
          }
        },
        "options": {
          "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      {
        "id": 4,
        "title": "Job Failures",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "datasource": {"type": "prometheus", "uid": "grafanacloud-prom"},
        "targets": [
          {
            "expr": "sum(rate(jobs_processed_total{status=\"failed\"}[5m])) by (queue)",
            "legendFormat": "{{queue}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"lineWidth": 2},
            "unit": "reqps",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.05},
                {"color": "red", "value": 0.1}
              ]
            }
          }
        },
        "options": {
          "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
          "tooltip": {"mode": "multi"}
        }
      },
      {
        "id": 5,
        "title": "Alloy Pipeline",
        "type": "logs",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 16},
        "datasource": {"type": "loki", "uid": "grafanacloud-logs"},
        "targets": [
          {
            "expr": "{service=\"alloy\"}",
            "refId": "A"
          }
        ],
        "options": {
          "dedupStrategy": "none",
          "enableLogDetails": true,
          "prettifyLogMessage": false,
          "showCommonLabels": false,
          "showLabels": true,
          "showTime": true,
          "sortOrder": "Descending",
          "wrapLogMessage": false
        }
      }
    ],
    "time": {"from": "now-1h", "to": "now"}
  },
  "overwrite": true,
  "folderId": 0
}
