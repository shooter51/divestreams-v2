{
  "name": "divestreams",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Multi-tenant dive shop management SaaS",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:coverage": "E2E_COVERAGE=true react-router dev",
    "start": "node --import ./lib/telemetry.mjs server/app.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "VITEST_INTEGRATION=true vitest run tests/integration",
    "test:integration:watch": "VITEST_INTEGRATION=true vitest tests/integration",
    "test:db:start": "bash scripts/setup-test-db.sh start",
    "test:db:stop": "bash scripts/setup-test-db.sh stop",
    "test:db:restart": "bash scripts/setup-test-db.sh restart",
    "test:db:reset": "bash scripts/setup-test-db.sh reset",
    "test:db:status": "bash scripts/setup-test-db.sh status",
    "test:e2e": "playwright test",
    "test:e2e:failing": "playwright test tests/e2e/workflow/public-site.spec.ts tests/e2e/workflow/customer-management.spec.ts",
    "test:e2e:coverage": "E2E_COVERAGE=true playwright test",
    "test:coverage": "vitest run --coverage",
    "test:coverage:unit": "vitest run tests/unit --coverage",
    "test:coverage:e2e": "E2E_COVERAGE=true playwright test tests/e2e/",
    "test:coverage:all": "npm run test:coverage:unit && npm run test:coverage:e2e && npm run coverage:merge",
    "coverage:merge": "tsx scripts/merge-coverage.ts",
    "coverage:report": "npx nyc report --reporter=text --reporter=html --report-dir=coverage/combined",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/run-migrations.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "seed:training": "tsx scripts/seed-training-data.ts",
    "seed:templates": "tsx scripts/seed-agency-templates.ts",
    "seed:images": "tsx scripts/seed-images.ts",
    "tenant:create": "tsx scripts/tenant-create.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "platform:setup": "tsx scripts/setup-platform-admin.ts",
    "email:verify": "tsx scripts/verify-email-config.ts",
    "worker": "tsx --import ./lib/telemetry.mjs lib/jobs/worker.ts",
    "worker:zapier": "tsx lib/jobs/zapier-webhook-worker.ts",
    "stripe:setup": "tsx scripts/create-stripe-prices.ts",
    "stripe:verify": "tsx scripts/verify-stripe-prices.ts",
    "stripe:sync-prices": "tsx scripts/sync-stripe-prices.ts",
    "stripe:verify-webhooks": "tsx scripts/verify-stripe-webhooks.ts",
    "stripe:test-upgrade": "tsx scripts/test-subscription-upgrade.ts",
    "pact:consumer": "vitest run tests/pact/consumer",
    "pact:provider": "vitest run tests/pact/provider",
    "pact:publish": "node scripts/publish-pacts.mjs",
    "pact:verify": "npm run pact:provider",
    "coverage:enforce": "tsx scripts/coverage-enforcer.ts",
    "coverage:enforce:unit": "tsx scripts/coverage-enforcer.ts --type=unit",
    "coverage:enforce:integration": "tsx scripts/coverage-enforcer.ts --type=integration",
    "coverage:enforce:e2e": "tsx scripts/coverage-enforcer.ts --type=e2e",
    "coverage:enforce:strict": "tsx scripts/coverage-enforcer.ts --strict",
    "test:scaffold": "tsx scripts/generate-test-scaffold.ts",
    "prepare": "test -d .git && bash scripts/install-hooks.sh || true",
    "hooks:install": "bash scripts/install-hooks.sh",
    "setup:verify": "bash scripts/verify-coverage-setup.sh",
    "validate:structure": "tsx scripts/validate-directory-structure.ts",
    "cleanup:structure": "tsx scripts/cleanup-directory-structure.ts",
    "git:cleanup": "scripts/cleanup-branches.sh",
    "git:cleanup:live": "scripts/cleanup-branches.sh --live",
    "seed:api": "tsx scripts/seed-api/index.ts",
    "seed:api:dev": "tsx scripts/seed-api/index.ts --env=dev",
    "seed:api:local": "tsx scripts/seed-api/index.ts --env=local",
    "seed:export": "tsx scripts/seed-api/export.ts",
    "seed:full": "npm run seed:api && npm run seed:export"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1004.0",
    "@aws-sdk/client-s3": "^3.967.0",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-text-align": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.2.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.0",
    "ioredis": "^5.6.0",
    "isbot": "^5.1.31",
    "isomorphic-dompurify": "^2.35.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^7.0.0",
    "pdf-lib": "^1.17.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.54.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@react-router/express": "7.12.0",
    "pino": "^10.3.1",
    "pino-http": "^10.0.0",
    "prom-client": "^15.0.0",
    "postgres": "^3.4.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-joyride": "^3.0.0-7",
    "react-router": "7.12.0",
    "sharp": "^0.34.5",
    "stripe": "^20.0.0",
    "tsx": "^4.20.0",
    "zod": "^3.25.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "tar": "^7.5.9"
  },
  "devDependencies": {
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@pact-foundation/pact": "^16.2.0",
    "@pact-foundation/pact-node": "^10.18.0",
    "@playwright/test": "^1.57.0",
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@testcontainers/postgresql": "^11.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/nodemailer": "^6.4.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^4.0.17",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.1.0",
    "msw": "^2.12.7",
    "nyc": "^17.1.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.1.7",
    "vite-plugin-istanbul": "^7.2.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.0"
  }
}
