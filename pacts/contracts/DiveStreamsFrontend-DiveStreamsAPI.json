{
  "consumer": {
    "name": "DiveStreamsFrontend"
  },
  "interactions": [
    {
      "description": "a POST request that exceeds the rate limit",
      "providerStates": [
        {
          "name": "user has exceeded their hourly question limit"
        }
      ],
      "request": {
        "body": {
          "question": "help"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.question": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/help"
      },
      "response": {
        "body": {
          "error": "Too many requests",
          "resetAt": 1700000000000
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.resetAt": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 429
      }
    },
    {
      "description": "a POST request with a DiveStreams question",
      "providerStates": [
        {
          "name": "user is authenticated and help articles exist"
        }
      ],
      "request": {
        "body": {
          "question": "How do I create a booking?"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.question": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/help"
      },
      "response": {
        "body": {
          "answer": "Go to the Bookings page and click New Booking.",
          "sources": [
            {
              "path": "docs/help/bookings.md",
              "title": "Managing Bookings"
            }
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.answer": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.sources": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.sources[*].path": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.sources[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a POST request with an off-topic question",
      "providerStates": [
        {
          "name": "user is authenticated but question has no matching articles"
        }
      ],
      "request": {
        "body": {
          "question": "xyzquux unrelated query"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.question": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/api/help"
      },
      "response": {
        "body": {
          "answer": "I can help with DiveStreams features",
          "sources": []
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.answer": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a POST request with missing question field",
      "providerStates": [
        {
          "name": "user is authenticated"
        }
      ],
      "request": {
        "body": {},
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/help"
      },
      "response": {
        "body": {
          "error": "question is required"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 400
      }
    },
    {
      "description": "a request for health status",
      "providerStates": [
        {
          "name": "all services are healthy"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/health"
      },
      "response": {
        "body": {
          "checks": {
            "database": "ok",
            "redis": "ok"
          },
          "status": "ok",
          "timestamp": "2024-01-01T12:00:00.000Z",
          "version": "2.0.0"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.checks.database": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.checks.redis": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss.SSSX",
                  "match": "datetime"
                }
              ]
            },
            "$.version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for health status with DB down",
      "providerStates": [
        {
          "name": "database is unavailable"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/health"
      },
      "response": {
        "body": {
          "checks": {
            "database": "error",
            "redis": "ok"
          },
          "status": "degraded",
          "timestamp": "2024-01-01T12:00:00.000Z",
          "version": "2.0.0"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.checks.database": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.checks.redis": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss.SSSX",
                  "match": "datetime"
                }
              ]
            },
            "$.version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 503
      }
    },
    {
      "description": "a request for health status with Redis down",
      "providerStates": [
        {
          "name": "redis is unavailable"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/api/health"
      },
      "response": {
        "body": {
          "checks": {
            "database": "ok",
            "redis": "error"
          },
          "status": "degraded",
          "timestamp": "2024-01-01T12:00:00.000Z",
          "version": "2.0.0"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.checks.database": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.checks.redis": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd'T'HH:mm:ss.SSSX",
                  "match": "datetime"
                }
              ]
            },
            "$.version": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 503
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.2.0"
    },
    "pactRust": {
      "ffi": "0.4.28",
      "models": "1.3.5"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "DiveStreamsAPI"
  }
}