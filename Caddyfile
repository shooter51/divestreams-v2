# NOTE: Mount /var/log/caddy as a volume in docker-compose to persist access logs.
# Example: - caddy_logs:/var/log/caddy

{
    email admin@divestreams.com
    on_demand_tls {
        ask http://app:3000/api/domain-check
    }
}

(security_headers) {
    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }
}

# DS-pfoc: CSP uses 'unsafe-inline' for script-src.
# Decision: Keep 'unsafe-inline' for now because React Router v7 injects inline scripts
# during client-side hydration. Nonce-based CSP requires the nonce to be injected into
# every inline script tag at render time, which React Router v7 does not support without
# a custom server integration. 'strict-dynamic' is not a viable drop-in replacement here
# because the hydration scripts are not loaded via trusted script elements.
# To remove 'unsafe-inline' in future: implement a nonce-aware server entry (entry.server.tsx)
# that sets a per-request nonce on the React Router scripts element and passes it through
# a custom header so Caddy can echo it back in the CSP header.

divestreams.com {
    reverse_proxy app:3000
    encode gzip

    import security_headers

    header {
        X-Frame-Options DENY
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' https: data:; connect-src 'self' https://api.stripe.com; frame-src 'self' https://*.divestreams.com https://*.test.divestreams.com; frame-ancestors 'none'"
    }

    log {
        output file /var/log/caddy/access.log
        format json
    }
}

www.divestreams.com {
    redir https://divestreams.com{uri} permanent
}

*.divestreams.com {
    tls {
        on_demand
    }

    encode gzip

    import security_headers

    header {
        X-Frame-Options SAMEORIGIN
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' https: data:; connect-src 'self' https://api.stripe.com; frame-src 'self' https://*.divestreams.com https://*.test.divestreams.com; frame-ancestors 'none'"
    }

    handle /embed/* {
        header -X-Frame-Options
        header Content-Security-Policy "frame-ancestors *"
        reverse_proxy app:3000
    }

    reverse_proxy app:3000

    log {
        output file /var/log/caddy/access.log
        format json
    }
}

# Catch-all for custom tenant domains (e.g., www.thediveshopla.com)
:443 {
    tls {
        on_demand
    }

    encode gzip

    import security_headers

    header {
        X-Frame-Options SAMEORIGIN
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' https: data:; connect-src 'self' https://api.stripe.com; frame-src 'self' https://*.divestreams.com https://*.test.divestreams.com; frame-ancestors 'none'"
    }

    handle /embed/* {
        header -X-Frame-Options
        header Content-Security-Policy "frame-ancestors *"
        reverse_proxy app:3000
    }

    reverse_proxy app:3000

    log {
        output file /var/log/caddy/access.log
        format json
    }
}
